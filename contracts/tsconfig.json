{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "hardhat"],
    "outDir": "dist"
  },
  "include": ["./hardhat.config.ts", "./scripts", "./contracts"]
}
